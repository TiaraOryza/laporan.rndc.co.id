APP_NAME="Laporan IT RNDC"
# APP_ENV: "production" (default) hides dev-only UI. Use "development" on local/dev boxes.
APP_ENV="production"
APP_URL="http://laporan.rndc.co.id"
APP_TIMEZONE="Asia/Jakarta"
DB_PATH="./storage/database.sqlite"
MAX_UPLOAD_MB=5

# WhatsApp (Fonnte compatible). Leave WA_ENABLED=false to disable sending.
WA_ENABLED=false
WA_API_URL="https://api.fonnte.com/send"
WA_API_TOKEN=""
WA_TARGET=""
